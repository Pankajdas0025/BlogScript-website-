#############################################
# ✅ BLOGSCRIPT - INFINITYFREE .HTACCESS
# Clean URLs + Basic Security (API Safe)
#############################################

Options -Indexes
ServerSignature Off

<IfModule mod_rewrite.c>
RewriteEngine On

# =========================
# ✅ 1) ALLOW API ROUTES FIRST
# (prevents security rules from blocking API)
# =========================
RewriteRule ^api/ - [L]

# =========================
# ✅ 2) BLOCK HIDDEN FILES/FOLDERS (.env, .git, etc.)
# =========================
RewriteRule (^|/)\. - [F,L]

# =========================
# ✅ 3) BLOCK SOME MALICIOUS QUERY STRINGS
# (removed < and > because it causes false blocks)
# =========================
RewriteCond %{QUERY_STRING} (\.\./|%2e%2e%2f|union.*select|concat\(|base64_encode|GLOBALS|_REQUEST) [NC,OR]
RewriteCond %{QUERY_STRING} (php://|filter=|input=|expect://) [NC]
RewriteRule .* - [F,L]

# =========================
# ✅ 4) IF FILE OR FOLDER EXISTS, DON'T REWRITE
# =========================
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# =========================
# ✅ 5) CLEAN URL ROUTES
# =========================
RewriteRule ^$ index.php [L]
RewriteRule ^home$ index.php [L]
RewriteRule ^register$ register.php [L]
RewriteRule ^admin$ admin.php [L]
RewriteRule ^profile$ profile.php [L]
# ✅CRUD ROUTES
RewriteRule ^create$ crud/create.php [L]
RewriteRule ^delete$ crud/delete.php [L]
RewriteRule ^update$ crud/update.php [L]
RewriteRule ^view$ crud/view.php [L]
# ✅AUTH ROUTES
RewriteRule ^update-user-password$ auth/updatepass.php [L]
RewriteRule ^reset-password$ auth/reset.php [L]
RewriteRule ^verification$ auth/verification.php [L]
# ✅ACTIONS ROUTES
RewriteRule ^login$ actions/login.php [L]
RewriteRule ^signup$ actions/signup.php [L]
RewriteRule ^logout$ actions/logout.php [L]

</IfModule>

# =========================
# 🔒 BLOCK SENSITIVE FILE TYPES
# =========================
<FilesMatch "\.(env|ini|log|sql|bak|old|zip|tar|gz|rar)$">
  Require all denied
</FilesMatch>

<FilesMatch "^(composer\.(json|lock)|package(-lock)?\.json|yarn\.lock)$">
  Require all denied
</FilesMatch>

#############################################
# ✅ END
#############################################
